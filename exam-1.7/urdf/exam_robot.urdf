<?xml version="1.0"?>
<robot name="exam_robot">
  <!-- Материалы -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  
  <!-- BASE LINK - корпус 0.4×0.3×0.1 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  
  <!-- ЛЕВОЕ КОЛЕСО -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="base_to_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.17 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- ПРАВОЕ КОЛЕСО -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="base_to_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.17 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- СЕНСОР -->
  <link name="sensor_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>
  
  <joint name="base_to_sensor" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_link"/>
    <origin xyz="0.2 0 0.08"/>
  </joint>
</robot>